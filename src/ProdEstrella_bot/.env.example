# ══════════════════════════════════════════════════════════════════════════════
# ProdEstrella Bot — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=production               # development | production
APP_DEBUG=false
APP_SECRET_KEY=change-me-to-a-32char-random-secret
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── Domains (used by Traefik labels) ──────────────────────────────────────────
APP_DOMAIN=api.productosestrella.club
EVO_DOMAIN=wsp.productosestrella.club
TRAEFIK_DASHBOARD_DOMAIN=traefik.productosestrella.club
DASH_DOMAIN=admin.productosestrella.club
# Domain shown in public short links (e.g. product.productosestrella.club/r/aBc1234)
LINK_DOMAIN=product.productosestrella.club

# Let's Encrypt — use a real email for cert notifications
ACME_EMAIL=dev@productosestrella.club

# ── Database (PostgreSQL 17) ────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=prodEstrella_db
POSTGRES_USER=prodEstrella_user
POSTGRES_PASSWORD=change-me-strong-db-password

# Constructed async DSN — used by SQLAlchemy asyncpg driver
# Format: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://prodEstrella_user:change-me-strong-db-password@db:5432/prodEstrella_db

# ── Redis 7.4 ─────────────────────────────────────────────────────────────────
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://:change-me-strong-redis-password@cache:6379/0

# Session TTL in seconds (default: 86400 = 24 hours)
REDIS_SESSION_TTL=86400

# ── WhatsApp Provider ─────────────────────────────────────────────────────────
# Valid values: evolution | meta
WHATSAPP_PROVIDER=evolution

# -- Evolution API v2.3.7 (self-hosted)
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=change-me-evolution-global-api-key
EVOLUTION_INSTANCE_NAME=prodEstrella-bot
# Typing delay: min and max seconds for human-like typing simulation
EVOLUTION_TYPING_MIN=1.0
EVOLUTION_TYPING_MAX=3.5

# -- Meta Cloud API (official)
META_PHONE_NUMBER_ID=your-meta-phone-number-id
META_WHATSAPP_TOKEN=your-meta-bearer-token
META_WEBHOOK_VERIFY_TOKEN=change-me-meta-webhook-verify-token
META_APP_SECRET=your-meta-app-secret

# ── Mercado Pago ──────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=your-mp-production-access-token
MP_PUBLIC_KEY=your-mp-public-key
MP_WEBHOOK_SECRET=change-me-mp-webhook-hmac-secret
# Notification URL for MP (must be publicly reachable)
MP_NOTIFICATION_URL=https://api.productosestrella.club/webhooks/mercadopago

# ── Google AI (Gemini) ────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-ai-studio-api-key

# Stage model routing
AI_STAGE1_MODEL=gemini-3.1-pro-preview         # Admin / product ingestion
AI_STAGE2_MODEL=gemini-3-flash-preview           # Negotiation (fast)
AI_STAGE3_MODEL=gemini-3.1-pro-preview         # Closing / transactional

# ── Evolution API — Shared Storage (points to our Postgres + Redis) ───────────
# These are used by the Evolution container, not our app directly
EVOLUTION_POSTGRES_URL=postgresql://prodEstrella_user:change-me-strong-db-password@db:5432/prodEstrella_db
EVOLUTION_REDIS_URL=redis://:change-me-strong-redis-password@cache:6379/1
